# Copy to .env and fill in values

GEMINI_API_KEY=
DATABASE_URL=sqlite:///./career_accelerator.db
SECRET_KEY=change-me
GROQ_API_KEY=

# ── Allowlist: only these emails get mail / can register ────────────────────
EMAIL_ALLOWLIST=you@gmail.com,friend@gmail.com
EMAIL_ALLOWLIST_ENFORCE_REGISTRATION=true

# ── SMTP (recommended with allowlist) ───────────────────────────────────────
EMAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com

API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
